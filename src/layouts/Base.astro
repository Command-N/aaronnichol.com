---
interface Props {
  title?: string;
  description?: string;
}

import '../styles/global.css';

const { title, description } = Astro.props;
const siteTitle = 'Aaron Nichol';
const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const pageDescription = description || 'Writing about agentic AI, enterprise technology, and building things.'; // Change this
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />

  <!-- Favicon - replace with your own -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

</head>
<body>
  <header class="site-header">
    <h1><a href="/">{siteTitle}</a></h1>
    <nav class="site-nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>&copy; {new Date().getFullYear()} {siteTitle}</p>
  </footer>
</body>
</html>

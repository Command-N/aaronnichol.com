---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allLinks = await getCollection('links', ({ data }) => !data.draft);
const allDrafts = import.meta.env.DEV ? await getCollection('drafts') : [];

type FeedItem = {
  type: 'post' | 'link';
  isDraft: boolean;
  id: string;
  data: any;
  render: () => Promise<{ Content: any }>;
};

const feed: FeedItem[] = [
  ...allPosts.map((p) => ({ ...p, type: 'post' as const, isDraft: false })),
  ...allLinks.map((l) => ({ ...l, type: 'link' as const, isDraft: false })),
  ...allDrafts.map((d) => ({ ...d, type: (d.data.url ? 'link' : 'post') as 'post' | 'link', isDraft: true })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base>
  <div class="feed">
    {feed.map(async (item) => {
      const { Content } = await item.render();
      const dateStr = item.data.date.toLocaleDateString('en-AU', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

      const year = item.data.date.getFullYear();
      const month = String(item.data.date.getMonth() + 1).padStart(2, '0');
      const slug = item.id.replace(/\.md$/, '');
      const permalink = `/${year}/${month}/${slug}`;

      if (item.type === 'link') {
        return (
          <article class="entry-link">
            <h2 class="entry-title">
              <a href={item.data.url} target="_blank" rel="noopener">{item.data.title}</a>
              {!item.isDraft && <a href={permalink} class="entry-permalink" title="Permalink">✦</a>}
              {item.isDraft && <span class="draft-badge">draft</span>}
            </h2>
            <div class="entry-body">
              <Content />
            </div>
            <div class="entry-meta">
              <time datetime={item.data.date.toISOString()}>{dateStr}</time>
            </div>
          </article>
        );
      }

      return (
        <article class="entry-post">
          <h2 class="entry-title">
            {item.isDraft
              ? <span>{item.data.title}</span>
              : <a href={permalink}>{item.data.title}</a>
            }
            {item.isDraft && <span class="draft-badge">draft</span>}
          </h2>
          <div class="entry-body">
            <Content />
          </div>
          <div class="entry-meta">
            <time datetime={item.data.date.toISOString()}>{dateStr}</time>
          </div>
        </article>
      );
    })}
  </div>
</Base>
